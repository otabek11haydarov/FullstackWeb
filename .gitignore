# ==========================================
# 🚀 Full-Stack Web Application .gitignore
# ==========================================

# ------------------------------------------
# 1. Dependency Directories
# ------------------------------------------
# Node.js backend & frontend modules
node_modules/
# Python virtual environments (if you use them for scripting/testing)
venv/
env/
.env/

# ------------------------------------------
# 2. Environment Variables & Secrets
# ------------------------------------------
# NEVER commit environment variables containing secrets, database credentials, or API keys!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ------------------------------------------
# 3. Build Outputs & Artifacts
# ------------------------------------------
# Production build folders for frontend (React/Vite/Webpack)
dist/
build/
out/
# Backend build artifacts
.build/
coverage/
.nyc_output/

# ------------------------------------------
# 4. OS-Specific Files
# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk
$RECYCLE.BIN/

# ------------------------------------------
# 5. IDE / Editor Settings
# ------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ / WebStorm
.idea/
*.iws
*.iml
*.ipr

# Other Editors
.fleet/
.sublime-project
.sublime-workspace

# ------------------------------------------
# 6. Logs and Runtime Files
# ------------------------------------------
# Log files generated by Node or other tools
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ------------------------------------------
# 7. Database Files (SQLite, etc.)
# ------------------------------------------
*.sqlite
*.sqlite3
*.db

# ------------------------------------------
# 8. Temporary Files
# ------------------------------------------
.temp/
.tmp/
tmp/
*.swp
*~
