# ==========================================
# 🚀 CareTrack Clinic - Full-Stack .gitignore
# ==========================================

# ------------------------------------------
# 1. Dependency Directories
# ------------------------------------------
node_modules/
**/node_modules/

# ------------------------------------------
# 2. Environment Variables & Secrets
# ------------------------------------------
# NEVER commit .env files — they contain DB credentials, JWT secrets, API keys
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# ------------------------------------------
# 3. Database Files
# ------------------------------------------
*.sqlite
*.sqlite3
*.db
database.json

# ------------------------------------------
# 4. Build & Distribution Output
# ------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/

# ------------------------------------------
# 5. Logs
# ------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------
# 6. OS Generated Files
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------
# 7. Editor & IDE Files
# ------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ------------------------------------------
# 8. Runtime & Cache Files
# ------------------------------------------
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo
.npm/
.yarn/
.pnp.*

# ------------------------------------------
# 9. Test & Coverage Output
# ------------------------------------------
coverage/
*.lcov
.nyc_output/

# ------------------------------------------
# 10. Temporary Files
# ------------------------------------------
tmp/
temp/
*.tmp

# ------------------------------------------
# 11. Debug / One-off Scripts (keep in local only)
# ------------------------------------------
backend/check_db.js
backend/test_*.js
backend/fix_*.js
backend/drop_*.js
backend/alter-*.js
backend/append_*.js
backend/fix-*.js
backend/syncDB.js
backend/seed_*.js
backend/seed_*.py
